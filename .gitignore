# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# Environment files (NEVER commit these!)
.env
.env*.local
.env.local
.env.development
.env.production

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Test coverage (generated)
coverage/

# Build artifacts
build.log
*.ipa
*.apk
*.aab

# Credentials (NEVER commit!)
credentials.json
credentials/

# Supabase local cache
supabase/.temp/

# SQL docs (database schema - keep local only)
docs/sql/
